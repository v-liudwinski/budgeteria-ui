# Auth0 Configuration (get from Auth0 dashboard)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_AUDIENCE=https://api.budgeteria.app

# API Base URL (for future ASP.NET Core backend)
VITE_API_BASE_URL=https://api.budgeteria.online/api

# Set to "true" to use mock services (default in dev)
VITE_USE_MOCKS=true
